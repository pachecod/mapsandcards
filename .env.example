# PostgreSQL connection string (provided by Render automatically)
DATABASE_URL=postgresql://user:pass@host:5432/mapsandcards
DATABASE_SSL=true

# Backblaze B2 (optional — needed for future media uploads)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=

# App password for the full editor (leave blank to disable).
# Protects /Tools/scroll-map-builder.html (without ?guest=1) and story
# create/save/delete/export. Guest Mode and story viewing stay public.
# Used by both `npm run dev` (Vite) and `npm start` (production).
APP_PASSWORD=

# Server port (Render sets PORT automatically)
PORT=3000
