# PostgreSQL connection string (provided by Render automatically)
DATABASE_URL=postgresql://user:pass@host:5432/mapsandcards
DATABASE_SSL=true

# Backblaze B2 (optional — needed for future media uploads)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=

# App password (leave blank to disable). Protects the non-guest builder and
# story create/save/delete/export API. Guest Mode (?guest=1) and story viewing stay public.
APP_PASSWORD=

# Server port (Render sets PORT automatically)
PORT=3000
